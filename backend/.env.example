NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/gigflow?retryWrites=true&w=majority&appName=Cluster0
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# Optional: SMTP credentials for email notifications (lead assigned / status changed).
# If unset, emails are logged to the console instead of sent — useful for local dev.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=GigFlow <noreply@gigflow.app>

# Optional: enables POST/GET /api/seed/run for resetting demo data.
# Both ENABLE_SEED_ROUTE=true and SEED_SECRET must be set, and this should
# never be enabled on a production deployment with real user data.
ENABLE_SEED_ROUTE=false
SEED_SECRET=
